{
  "name": "claude-patrol",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "claude-patrol": "./bin/claude-patrol.js"
  },
  "scripts": {
    "setup:xterm": "bash scripts/setup-xterm.sh",
    "setup": "bash scripts/setup.sh",
    "build": "pnpm --filter claude-patrol-frontend build",
    "start": "bash scripts/build-if-stale.sh && bash scripts/start-loop.sh",
    "watch": "bash scripts/build-if-stale.sh && node src/watch.js",
    "lint": "biome check src/ frontend/src/",
    "test": "node --test src/**/*.test.js"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fastify": "^5.8.2",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  }
}
