{
  "name": "claude-patrol",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "claude-patrol": "./bin/claude-patrol.js"
  },
  "scripts": {
    "setup:xterm": "bash scripts/setup-xterm.sh",
    "start": "([ -d vendor/xterm.js/lib ] || pnpm run setup:xterm) && pnpm --filter claude-patrol-frontend build && node src/index.js",
    "watch": "([ -d vendor/xterm.js/lib ] || pnpm run setup:xterm) && pnpm --filter claude-patrol-frontend build && node src/watch.js",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true",
    "lint": "biome check src/ frontend/src/",
    "test": "node --test src/**/*.test.js"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fastify": "^5.8.2",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  }
}
