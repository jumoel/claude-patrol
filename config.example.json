{
  "orgs": ["your-org"],
  "poll_interval_seconds": 600,
  "db_path": "./data/claude-patrol.db",
  "port": 3000,
  "workspace_base_path": "~/.claude-patrol/workspaces",
  "work_dir": "~/work",
  "global_terminal_cwd": "~/work",
  "symlink_memory": true,
  "repos": {
    "your-org/your-repo": {
      "symlinks": [
        "./path/to/secret-file"
      ],
      "initCommands": [
        "npm install"
      ]
    }
  }
}
